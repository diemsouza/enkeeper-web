enum NoteType {
    text
    audio
    image
}

enum MessageRole {
    user
    assistant
}

model Note {
    id         String    @id @default(ulid()) @map("id")
    userId     String    @map("user_id")
    noteType   NoteType  @default(text) @map("note_type")
    content    String    @map("content") // texto final ou resumo IA
    rawContent String?   @map("raw_content") // transcrição/OCR bruto — null se texto direto
    fileUrl    String?   @map("file_url") // path no storage (R2/S3) — null se texto direto
    messageId  String?   @map("message_id")
    createdAt  DateTime  @default(now()) @map("created_at")
    updatedAt  DateTime  @updatedAt @map("updated_at")
    deletedAt  DateTime? @map("deleted_at")

    user             User       @relation(fields: [userId], references: [id])
    message          Message?   @relation(fields: [messageId], references: [id])
    noteTagRelations NoteTag[]
    llmUsages        LlmUsage[]

    @@index([userId])
    @@index([userId, createdAt])
    @@map("notes")
}

model Tag {
    id        String    @id @default(ulid()) @map("id")
    userId    String    @map("user_id")
    name      String    @map("name") // "ingles", "phrasal", "trabalho"
    noteCount Int       @default(0) @map("note_count") // counter cache
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")
    deletedAt DateTime? @map("deleted_at")

    user     User      @relation(fields: [userId], references: [id])
    noteTags NoteTag[]

    @@unique([userId, name])
    @@index([userId])
    @@map("tags")
}

model NoteTag {
    noteId    String   @map("note_id")
    tagId     String   @map("tag_id")
    createdAt DateTime @default(now()) @map("created_at")

    note Note @relation(fields: [noteId], references: [id])
    tag  Tag  @relation(fields: [tagId], references: [id])

    @@id([noteId, tagId])
    @@map("note_tags")
}

model DailyUsage {
    id        String   @id @default(ulid()) @map("id")
    userId    String   @map("user_id")
    date      DateTime @map("date") @db.Date // só a data, sem hora
    noteCount Int      @default(0) @map("note_count")
    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id])

    @@unique([userId, date])
    @@map("daily_usages")
}

enum AiProvider {
    openai
    anthropic
    google
}

model LlmUsage {
    id           String     @id @default(ulid()) @map("id")
    userId       String     @map("user_id")
    noteId       String?    @map("note_id") // null se não for relacionado a uma nota
    usageType    String     @map("usage_type") // "transcription", "ocr", "summary"
    provider     AiProvider @default(openai) @map("provider")
    model        String     @map("model")
    inputTokens  Int        @default(0) @map("input_tokens")
    outputTokens Int        @default(0) @map("output_tokens")
    totalTokens  Int        @default(0) @map("total_tokens")
    cachedTokens Int        @default(0) @map("cached_tokens")
    createdAt    DateTime   @default(now()) @map("created_at")

    user User  @relation(fields: [userId], references: [id])
    note Note? @relation(fields: [noteId], references: [id])

    @@index([userId])
    @@index([noteId])
    @@map("llm_usages")
}

model Message {
    id            String      @id @default(ulid()) @map("id")
    userId        String      @map("user_id")
    userChannelId String      @map("user_channel_id")
    role          MessageRole @map("role")
    content       String      @map("content")
    intent        String?     @map("intent")
    externalId    String?     @map("external_id")
    metadata      Json?       @map("metadata")
    createdAt     DateTime    @default(now()) @map("created_at")

    user        User        @relation(fields: [userId], references: [id])
    userChannel UserChannel @relation(fields: [userChannelId], references: [id])
    notes       Note[]

    @@unique([userChannelId, externalId])
    @@index([userId, createdAt])
    @@index([userId, role, createdAt])
    @@map("messages")
}
