enum DocType {
    text
    audio
    image
    pdf
}

enum DocStatus {
    processing
    active
    paused
    archived
}

enum ActivityStatus {
    active
    paused
    completed
}

enum MessageRole {
    user
    assistant
}

enum AiProvider {
    openai
    anthropic
    google
}

model Doc {
    id         String    @id @default(ulid()) @map("id")
    userId     String    @map("user_id")
    messageId  String?   @map("message_id")
    title      String    @map("title")
    docType    DocType   @map("doc_type")
    rawContent String    @map("raw_content") @db.Text
    content    String    @map("content") @db.Text
    topicsData Json      @map("topics_data")
    status     DocStatus @default(processing) @map("status")
    createdAt  DateTime  @default(now()) @map("created_at")
    updatedAt  DateTime  @updatedAt @map("updated_at")
    deletedAt  DateTime? @map("deleted_at")

    user       User       @relation(fields: [userId], references: [id])
    message    Message?   @relation(fields: [messageId], references: [id])
    activities Activity[]
    llmUsages  LlmUsage[]

    @@index([userId])
    @@index([userId, status])
    @@map("docs")
}

model Activity {
    id              String         @id @default(ulid()) @map("id")
    userId          String         @map("user_id")
    docId           String         @map("doc_id")
    date            DateTime       @map("date") @db.Date
    topicIndex      Int            @default(0) @map("topic_index")
    nextMessageAt   DateTime?      @map("next_message_at")
    intervalMinutes Int            @default(60) @map("interval_minutes")
    lastUserReply   String?        @map("last_user_reply") @db.Text
    status          ActivityStatus @default(active) @map("status")
    pausedAt        DateTime?      @map("paused_at")
    completedAt     DateTime?      @map("completed_at")
    createdAt       DateTime       @default(now()) @map("created_at")
    updatedAt       DateTime       @updatedAt @map("updated_at")
    deletedAt       DateTime?      @map("deleted_at")

    user     User      @relation(fields: [userId], references: [id])
    doc      Doc       @relation(fields: [docId], references: [id])
    messages Message[]

    @@unique([userId, docId, date])
    @@index([status, nextMessageAt])
    @@map("activities")
}

model WeeklyReport {
    id            String    @id @default(ulid()) @map("id")
    userId        String    @map("user_id")
    reportContent String    @map("report_content") @db.Text
    summaryData   Json      @map("summary_data")
    sentAt        DateTime? @map("sent_at")
    createdAt     DateTime  @default(now()) @map("created_at")
    deletedAt     DateTime? @map("deleted_at")

    user User @relation(fields: [userId], references: [id])

    @@index([userId])
    @@map("weekly_reports")
}

model LlmUsage {
    id           String     @id @default(ulid()) @map("id")
    userId       String     @map("user_id")
    docId        String?    @map("doc_id")
    // "transcription" | "ocr" | "topic_extraction" | "practice_generation" | "weekly_report"
    usageType    String     @map("usage_type")
    provider     AiProvider @default(openai) @map("provider")
    model        String     @map("model")
    inputTokens  Int        @default(0) @map("input_tokens")
    outputTokens Int        @default(0) @map("output_tokens")
    totalTokens  Int        @default(0) @map("total_tokens")
    cachedTokens Int        @default(0) @map("cached_tokens")
    createdAt    DateTime   @default(now()) @map("created_at")

    user User @relation(fields: [userId], references: [id])
    doc  Doc? @relation(fields: [docId], references: [id])

    @@index([userId])
    @@index([docId])
    @@map("llm_usages")
}

model Message {
    id            String      @id @default(ulid()) @map("id")
    userId        String      @map("user_id")
    userChannelId String      @map("user_channel_id")
    activityId    String?     @map("activity_id")
    role          MessageRole @map("role")
    content       String      @map("content")
    intent        String?     @map("intent")
    externalId    String?     @map("external_id")
    mediaType     String?     @map("media_type")
    mediaId       String?     @map("media_id")
    metadata      Json?       @map("metadata")
    createdAt     DateTime    @default(now()) @map("created_at")

    user        User        @relation(fields: [userId], references: [id])
    userChannel UserChannel @relation(fields: [userChannelId], references: [id])
    activity    Activity?   @relation(fields: [activityId], references: [id])
    docs        Doc[]

    @@unique([userChannelId, externalId])
    @@index([userId, createdAt])
    @@index([userId, role, createdAt])
    @@map("messages")
}
