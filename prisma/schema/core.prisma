enum DocType {
    text
    audio
    image
    pdf
    mixed
}

enum DocStatus {
    processing
    active
    paused
    archived
    failed
    pending
    canceled
}

enum ActivityStatus {
    active
    paused
    archived
    cancelled
    completed
    abandoned
}

enum MessageRole {
    user
    assistant
}

enum AiProvider {
    openai
    anthropic
    google
}

enum QuestionStatus {
    pending
    right
    partial
    wrong
}

enum QuestionType {
    text
    audio
}

enum AnswerType {
    text
    audio
}

enum SectionType {
    vocabulary
    text
    exercise
}

enum SectionStatus {
    pending
    partial
    completed
}

enum QuestionFormat {
    gap_fill // frase com lacuna no meio: "I found the ______ between work and enjoy."
    recall // dado o contexto ou uso, traga o termo: "Como se diz 'deixa pra lá' em inglês?"
    recall_inverted // dado o termo, traga o significado ou uso: "O que significa 'never mind'?"
    scenario // situação realista, qual termo usaria: "Você quer pedir pra alguém esperar. O que diz?"
    choice // duas ou mais opções, escolhe a correta: "Qual usaria: 'never mind' ou 'no way'?"
    open_text // gerado a partir de texto corrido
    open_question // pergunta direta com resposta objetiva
}

enum Level {
    basic
    intermediate
    advanced
}

model Message {
    id            String      @id @default(ulid()) @map("id")
    userId        String      @map("user_id")
    userChannelId String      @map("user_channel_id")
    activityId    String?     @map("activity_id")
    role          MessageRole @map("role")
    content       String      @map("content")
    intent        String?     @map("intent")
    externalId    String?     @map("external_id")
    mediaType     String?     @map("media_type")
    mediaId       String?     @map("media_id")
    metadata      Json?       @map("metadata")
    questionId    String?     @map("question_id")
    createdAt     DateTime    @default(now()) @map("created_at")

    user        User        @relation(fields: [userId], references: [id])
    userChannel UserChannel @relation(fields: [userChannelId], references: [id])
    activity    Activity?   @relation(fields: [activityId], references: [id])
    docItems    DocItem[]

    @@unique([userChannelId, externalId])
    @@index([userId, createdAt])
    @@index([userId, role, createdAt])
    @@map("messages")
}

model Doc {
    id         String    @id @default(ulid()) @map("id")
    userId     String    @map("user_id")
    title      String?   @map("title")
    docType    DocType   @map("doc_type")
    level      Level     @default(basic) @map("level")
    rawContent String?   @map("raw_content") @db.Text
    content    String?   @map("content") @db.Text
    status     DocStatus @default(processing) @map("status")
    error      String?   @map("error")
    createdAt  DateTime  @default(now()) @map("created_at")
    updatedAt  DateTime  @updatedAt @map("updated_at")
    deletedAt  DateTime? @map("deleted_at")

    user       User       @relation(fields: [userId], references: [id])
    activities Activity[]
    llmUsages  LlmUsage[]
    sections   Section[]
    llmLogs    LlmLog[]
    docItems   DocItem[]

    @@index([userId])
    @@index([userId, status])
    @@map("docs")
}

model Activity {
    id                String         @id @default(ulid()) @map("id")
    userId            String         @map("user_id")
    docId             String         @map("doc_id")
    date              DateTime       @map("date") @db.Date
    nextMessageAt     DateTime?      @map("next_message_at")
    intervalMinutes   Int            @default(60) @map("interval_minutes")
    executionCount    Int            @default(0) @map("execution_count")
    waitingUser       Boolean        @default(false) @map("waiting_user")
    interactionCount  Int            @default(0) @map("interaction_count")
    lastInteractionAt DateTime?      @map("last_interaction_at")
    status            ActivityStatus @default(active) @map("status")
    pausedAt          DateTime?      @map("paused_at")
    completedAt       DateTime?      @map("completed_at")
    intensiveUntil    DateTime?      @map("intensive_until")
    questionCount     Int            @default(0) @map("question_count")
    questionLimit     Int            @default(0) @map("question_limit")
    sectionCount      Int            @default(0) @map("section_count")
    roundCompleted    Boolean        @default(false) @map("round_completed")
    lastQuestionId    String?        @map("last_question_id")
    summary           String?        @map("summary")
    userLevel         Level          @default(basic) @map("user_level")
    title             String         @default("") @map("title")
    lastNudgeStep     String?        @map("last_nudge_step")
    lastNudgeAt       DateTime?      @map("last_nudge_at")
    createdAt         DateTime       @default(now()) @map("created_at")
    updatedAt         DateTime       @updatedAt @map("updated_at")
    deletedAt         DateTime?      @map("deleted_at")

    user      User       @relation(fields: [userId], references: [id])
    doc       Doc        @relation(fields: [docId], references: [id])
    messages  Message[]
    questions Question[]
    sections  Section[]

    @@unique([userId, docId, date])
    @@index([status, nextMessageAt])
    @@map("activities")
}

model Section {
    id          String         @id @default(ulid()) @map("id")
    userId      String         @map("user_id")
    docId       String?        @map("doc_id")
    activityId  String         @map("activity_id")
    sectionType SectionType    @map("section_type")
    title       String         @map("title")
    content     String         @map("content") @db.Text
    order       Int            @map("order")
    status      SectionStatus? @map("status")
    createdAt   DateTime       @default(now()) @map("created_at")
    updatedAt   DateTime       @updatedAt @map("updated_at")
    deletedAt   DateTime?      @map("deleted_at")

    user      User       @relation(fields: [userId], references: [id])
    doc       Doc?       @relation(fields: [docId], references: [id])
    activity  Activity   @relation(fields: [activityId], references: [id])
    questions Question[]
    llmUsages LlmUsage[]
    llmLogs   LlmLog[]

    @@index([userId])
    @@index([activityId, status])
    @@map("sections")
}

model Question {
    id              String          @id @default(ulid()) @map("id")
    activityId      String          @map("activity_id")
    sectionId       String?         @map("section_id")
    question        String          @db.Text
    answerKeys      String[]        @map("answer_keys")
    answer          String?         @db.Text
    questionType    QuestionType    @default(text) @map("question_type")
    answerType      AnswerType?     @map("answer_type")
    questionFormat  QuestionFormat? @map("question_format")
    questionOptions String[]        @map("question_options")
    attemptCount    Int             @default(0) @map("attempt_count")
    revisionCount   Int             @default(0) @map("revision_count")
    wrongCount      Int             @default(0) @map("wrong_count")
    status          QuestionStatus? @map("status")
    easeFactor      Float           @default(2.5) @map("ease_factor")
    interval        Int             @default(0) @map("interval")
    nextRevisionAt  DateTime?       @map("next_revision_at")
    createdAt       DateTime        @default(now()) @map("created_at")
    updatedAt       DateTime        @updatedAt @map("updated_at")
    deletedAt       DateTime?       @map("deleted_at")

    activity Activity @relation(fields: [activityId], references: [id])
    section  Section? @relation(fields: [sectionId], references: [id])

    @@index([activityId, status])
    @@index([sectionId])
    @@map("questions")
}

model DocItem {
    id         String   @id @default(ulid()) @map("id")
    docId      String   @map("doc_id")
    userId     String   @map("user_id")
    messageId  String?  @map("message_id")
    docType    DocType  @map("doc_type")
    rawContent String   @map("raw_content") @db.Text
    error      String?  @map("error")
    order      Int      @map("order")
    createdAt  DateTime @default(now()) @map("created_at")
    updatedAt  DateTime @updatedAt @map("updated_at")

    doc     Doc      @relation(fields: [docId], references: [id])
    user    User     @relation(fields: [userId], references: [id])
    message Message? @relation(fields: [messageId], references: [id])

    @@index([docId])
    @@index([userId])
    @@map("doc_items")
}

model WeeklyReport {
    id            String    @id @default(ulid()) @map("id")
    userId        String    @map("user_id")
    reportContent String    @map("report_content") @db.Text
    summaryData   Json      @map("summary_data")
    sentAt        DateTime? @map("sent_at")
    createdAt     DateTime  @default(now()) @map("created_at")
    deletedAt     DateTime? @map("deleted_at")

    user User @relation(fields: [userId], references: [id])

    @@index([userId])
    @@map("weekly_reports")
}

model LlmUsage {
    id           String     @id @default(ulid()) @map("id")
    userId       String     @map("user_id")
    docId        String?    @map("doc_id")
    sectionId    String?    @map("section_id")
    usageType    String     @map("usage_type")
    provider     AiProvider @default(openai) @map("provider")
    model        String     @map("model")
    inputTokens  Int        @default(0) @map("input_tokens")
    outputTokens Int        @default(0) @map("output_tokens")
    totalTokens  Int        @default(0) @map("total_tokens")
    cachedTokens Int        @default(0) @map("cached_tokens")
    createdAt    DateTime   @default(now()) @map("created_at")

    user    User     @relation(fields: [userId], references: [id])
    doc     Doc?     @relation(fields: [docId], references: [id])
    section Section? @relation(fields: [sectionId], references: [id])

    @@index([userId])
    @@index([docId])
    @@index([sectionId])
    @@map("llm_usages")
}

model LlmLog {
    id           String     @id @default(ulid()) @map("id")
    userId       String?    @map("user_id")
    docId        String?    @map("doc_id")
    sectionId    String?    @map("section_id")
    questionId   String?    @map("question_id")
    stage        String     @map("stage")
    provider     AiProvider @default(openai) @map("provider")
    model        String     @map("model")
    input        Json       @map("input")
    output       Json?      @map("output")
    parsedOutput Json?      @map("parsed_output")
    success      Boolean    @default(true) @map("success")
    error        String?    @map("error")
    inputTokens  Int        @default(0) @map("input_tokens")
    outputTokens Int        @default(0) @map("output_tokens")
    totalTokens  Int        @default(0) @map("total_tokens")
    cachedTokens Int        @default(0) @map("cached_tokens")
    durationMs   Int?       @map("duration_ms")
    createdAt    DateTime   @default(now()) @map("created_at")

    user    User?    @relation(fields: [userId], references: [id])
    doc     Doc?     @relation(fields: [docId], references: [id])
    section Section? @relation(fields: [sectionId], references: [id])

    @@index([userId])
    @@index([docId])
    @@index([stage])
    @@index([createdAt])
    @@map("llm_logs")
}

enum WaitlistStatus {
    pending
    invited
    active
}

model Waitlist {
    id        String         @id @default(ulid()) @map("id")
    name      String
    phone     String         @unique
    status    WaitlistStatus @default(pending)
    createdAt DateTime       @default(now()) @map("created_at")
    updatedAt DateTime       @updatedAt @map("updated_at")

    @@map("waitlist")
}
