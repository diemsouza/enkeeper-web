enum UserStatus {
    active
    suspended
    disabled
}

enum PlanCode {
    trial
    pro
}

enum PlanStatus {
    active
    canceled
    past_due
    expired
}

enum ChannelType {
    whatsapp
}

model User {
    id       String  @id @default(ulid()) @map("id")
    name     String? @map("name")
    email    String? @unique @map("email")
    imageUrl String? @map("image_url")
    locale   String? @map("locale")
    currency String? @map("currency")

    // plano - atualizado pelo webhook Stripe ou manualmente no MVP
    planCode      PlanCode   @default(trial) @map("plan_code")
    planStatus    PlanStatus @default(active) @map("plan_status")
    planExpiresAt DateTime?  @map("plan_expires_at")

    onboardedAt DateTime?  @map("onboarded_at")
    status      UserStatus @default(active) @map("status")
    createdAt   DateTime   @default(now()) @map("created_at")
    updatedAt   DateTime   @updatedAt @map("updated_at")
    deletedAt   DateTime?  @map("deleted_at")

    channels      UserChannel[]
    docs          Doc[]
    activities    Activity[]
    weeklyReports WeeklyReport[]
    llmUsages     LlmUsage[]
    messages      Message[]
    dailyUsages   DailyUsage[]

    @@map("users")
}

model DailyUsage {
    id                String   @id @default(ulid()) @map("id")
    userId            String   @map("user_id")
    date              DateTime @map("date") @db.Date
    docCount          Int      @default(0) @map("doc_count")
    userMessageCount  Int      @default(0) @map("user_message_count")
    agentMessageCount Int      @default(0) @map("agent_message_count")
    messagesCount     Int      @default(0) @map("messages_count")
    createdAt         DateTime @default(now()) @map("created_at")
    updatedAt         DateTime @updatedAt @map("updated_at")

    user User @relation(fields: [userId], references: [id])

    @@unique([userId, date])
    @@map("daily_usages")
}

model UserChannel {
    id          String      @id @default(ulid()) @map("id")
    userId      String      @map("user_id")
    channelType ChannelType @map("channel_type")
    channelId   String      @map("channel_id") // BSUID Meta, userId Telegram, etc
    channelCode String?     @map("channel_code") // telefone, username - legível
    metadata    Json?       @map("metadata")
    createdAt   DateTime    @default(now()) @map("created_at")
    updatedAt   DateTime    @updatedAt @map("updated_at")

    user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    messages Message[]

    @@unique([channelType, channelId])
    @@unique([channelType, channelCode])
    @@index([userId])
    @@map("user_channels")
}
